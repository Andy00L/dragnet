{
  "name": "dragnet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "setup:contracts": "bash scripts/setup-contracts.sh",
    "test:contracts": "cd contracts && forge test",
    "test:crypto": "bun test packages/crypto",
    "test:sdk": "bun test packages/sdk",
    "typecheck": "bunx tsc --build --verbose",
    "buyer": "bun run packages/buyer/src/cli.ts",
    "scanner": "bun run packages/scanner/src/cli.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.6.0"
  }
}
