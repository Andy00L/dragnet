# Dragnet configuration. Copy to .env and fill in. Never commit .env (it is gitignored).

# Target chain: testnet (Monad testnet, the default), mainnet (Monad mainnet), or local (anvil).
DRAGNET_CHAIN=testnet

# RPC URL. Optional: defaults to the selected chain's public RPC.
#   Monad testnet: https://testnet-rpc.monad.xyz  (chainId 10143)
#   Monad mainnet: https://rpc.monad.xyz          (chainId 143)
#   local anvil:   http://127.0.0.1:8545          (chainId 31337)
# DRAGNET_RPC_URL=

# Deployed DragnetMarket address. Required by the buyer and scanner clients.
DRAGNET_MARKET=

# Signing key for the buyer or a worker: 0x-prefixed 32-byte hex.
# Fund a testnet key with MON from https://faucet.monad.xyz before posting bounties.
PRIVATE_KEY=
